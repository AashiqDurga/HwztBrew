# =============================================================================
# ~/.aliases — handy shortcuts (symlinked from the mac-setup repo)
# =============================================================================

# Modern replacements (installed via Brewfile)
alias ls='eza --group-directories-first'
alias ll='eza -la --group-directories-first --git'
alias la='eza -a'
alias lt='eza --tree --level=2'
alias cat='bat'
alias cd='z'                 # zoxide
alias grep='rg'

# Git
alias g='git'
alias gs='git status'
alias ga='git add'
alias gc='git commit'
alias gp='git push'
alias gl='git pull'
alias gco='git checkout'
alias gd='git diff'
alias glog='git log --oneline --graph --decorate -20'
alias lg='lazygit'

# Navigation
alias ..='cd ..'
alias ...='cd ../..'
alias ....='cd ../../..'

# Misc
alias reload='exec zsh'
alias path='echo $PATH | tr ":" "\n"'
alias ip='ipconfig getifaddr en0'

# Claude Code sandbox — the `ccx` command (run Claude in a per-project Docker
# Sandbox microVM, fully autonomous). The function's single source lives in the
# kit and is installed to ~/.config/claude-sandbox/ccx.sh by claude-code.sh.
[ -f ~/.config/claude-sandbox/ccx.sh ] && source ~/.config/claude-sandbox/ccx.sh
