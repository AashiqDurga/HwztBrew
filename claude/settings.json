{
  "statusLine": {
    "type": "command",
    "command": "~/.claude/statusline.sh"
  },
  "sandbox": {
    "enabled": true,
    "excludedCommands": ["gh *", "docker *", "gcloud *", "terraform *"],
    "filesystem": {
      "denyRead": [
        "~/.ssh",
        "~/.aws",
        "~/.config/gh",
        "~/.config/gcloud",
        "~/.npmrc",
        "~/.docker/config.json",
        "~/.kube",
        "~/.gnupg",
        "~/.netrc",
        "~/.terraform.d"
      ]
    }
  }
}
